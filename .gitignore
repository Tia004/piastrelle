/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js build and cache
/.next/
/out/

# Production builds
/build
/dist

# Debug and Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Sensitive Credentials & Local Environment variables
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.cert
credentials.json
service-account*.json
.firebase/
.gc/

# Vercel deployment metadata
.vercel

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Operating System Files
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# IDEs & Editor configurations
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# Temporary files & backup
tmp/
temp/
*~
~*
